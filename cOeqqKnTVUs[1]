            findCurrentItemByTimestampMs(targetTimestampMs) {
                const filteredNotDeletedItems = this.getFilteredNotDeletedItems();

                
                const exactMatch = filteredNotDeletedItems.find(item => item.timestampMs === targetTimestampMs);
                if (exactMatch) {
                    return exactMatch;
                }

                
                let closestItem = null;
                let smallestDifference = Infinity;

                for (const item of filteredNotDeletedItems) {
                    const difference = Math.abs(item.timestampMs - targetTimestampMs);
                    if (difference < smallestDifference) {
                        smallestDifference = difference;
                        closestItem = item;
                    }
                }

                return closestItem;
