                }

                if (this.isLastTimelineItemLessThanContentTimestamp(this.hmsToSeconds(this.$el.textContent) * 1000)) {
                    this.$el.textContent = this.timelineItems[id].timestamp;
                    return;
                }

                this.actions.push({
                    type: 'storeTimestamp',
                    id: id,
                    oldTimestamp: this.timelineItems[id].timestamp,
                    oldDurationMs: this.timelineItems[id].durationMs,
                });

                this.$refs['timelineInput'].dispatchEvent(new Event('input', { bubbles: true }));
                this.timelineItems[id].timestamp = this.$el.textContent;
                this.timelineItems[id].timestampMs = this.hmsToSeconds(this.$el.textContent) * 1000;
                this.timelineItems[id].durationMs = (this.timelineItems[id].type === 'caption')
                    ? this.calculateCaptionDurationMs(id, this.timelineItems[id].copy, 'storeTimestamp')
