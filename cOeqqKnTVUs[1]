            calculateCaptionDurationMs(id, text, action) {
                
                if (action === 'storeCopy' && (this.timelineItems[id].ai || this.timelineItems[id].uploaded)) {
                    return this.timelineItems[id].durationMs;
                }

                const item = this.timelineItems[id];

                
                const wordsPerSecond = 3;
                const wordCount = text.trim().split(/\s+/).length;
                const calculatedDurationMs = Math.ceil(wordCount / wordsPerSecond) * 1000;

                const nextItem = this.getNextTimelineItem(id);
                if (nextItem && nextItem.timestampMs > item.timestampMs) {
                    const availableDurationMs = nextItem.timestampMs - item.timestampMs;
                    return Math.min(calculatedDurationMs, availableDurationMs);
                } else {
                    return calculatedDurationMs;
                }
            },
            updatePreviousItemDuration(newItemId) {
                const newItem = this.timelineItems[newItemId];

                
                if (!newItem) return;

                
                let prev = null;
                Object.values(this.timelineItems).forEach(item => {
                    if (
                        item.type === newItem.type
                        && item.id !== newItemId
                        && !item.deleted
                        && item.timestampMs < newItem.timestampMs
                        && (!prev || item.timestampMs > prev.timestampMs)
                    ) {
                        prev = item;
                    }
                });

                
                if (prev) {
                    prev.durationMs = newItem.timestampMs - prev.timestampMs;

                    this.timelineItems[prev.id].durationMs = prev.durationMs;
                }
            },
            getNextTimelineItem(id) {
                const filteredNotDeletedItems = this.getFilteredNotDeletedItems();
                filteredNotDeletedItems.sort((a, b) => a.timestampMs - b.timestampMs);

